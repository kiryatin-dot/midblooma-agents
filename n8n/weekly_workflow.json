      "id": "w1a00001-0000-0000-0000-000000000003",
      "name": "Read Content Log (Past 4 Weeks)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [340, 500],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "cz1Yn9DYkoqHaQfb",
          "name": "Google Sheets (Midblooma)"
        }
      },
      "notes": "Content Log tab: column 'topic' with one row per published article."
    },
    {
      "parameters": {
        "jsCode": "// Build the trend_envelopes array and content_log from Google Sheets rows\nconst trendRows = $('Read 7-Day Trend Signals').all().map(i => i.json);\nconst contentRows = $('Read Content Log (Past 4 Weeks)').all().map(i => i.json);\n\n// Filter trend rows to the last 7 days\nconst sevenDaysAgo = new Date();\nsevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);\n\n// Group rows into per-day envelopes (one envelope per unique run_id)\nconst envelopeMap = {};\nfor (const row of trendRows) {\n  if (!row.run_id) continue;\n  const rowDate = new Date(row.date);\n  if (rowDate < sevenDaysAgo) continue;\n  if (!envelopeMap[row.run_id]) {\n    envelopeMap[row.run_id] = {\n      agent_id: 'trend_scout',\n      timestamp: row.date + 'T06:00:00Z',\n      run_id: row.run_id,\n      cadence: 'daily',\n      status: 'ok',\n      payload: { signals: [], date: row.date },\n      notes: ''\n    };\n  }\n  envelopeMap[row.run_id].payload.signals.push({\n    rank: parseInt(row.rank) || 1,\n    source: row.source || '',\n    title: row.title || '',\n    url: row.url || '',\n    engagement_score: parseInt(row.engagement_score) || 0,\n    pain_point: row.pain_point || '',\n    content_angle: row.content_angle || ''\n  });\n}\n\nconst trendEnvelopes = Object.values(envelopeMap);\nconst contentLog = contentRows.map(r => r.topic).filter(Boolean);\n\n// Generate a run_id for this weekly run\nconst runId = 'weekly-' + new Date().toISOString().slice(0,10);\n\nreturn [{ json: { trend_envelopes: trendEnvelopes, content_log: contentLog, run_id: runId } }];"
      },
      "id": "w1a00001-0000-0000-0000-000000000004",
